# Client: see client/.env.example (optional VITE_API_URL when API is not same-origin)

# API (server) — copy to server/.env
# App queries (can be pooled, e.g. Supabase port 6543 + pgbouncer)
DATABASE_URL="postgresql://four:four@localhost:5432/four"
# Migrations / Prisma CLI: use a direct Postgres URL when your DATABASE_URL is pooled (optional locally)
# DIRECT_URL="postgresql://four:four@localhost:5432/four"
PORT=3001
CORS_ORIGIN="http://localhost:5173"
