# Copy to `.env` in the repo root (Next.js loads env from the project directory).

# Canonical site URL for sitemap, Open Graph, and JSON-LD (no trailing slash). Use your production domain on Vercel.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# App / Prisma queries — use Supabase pooler in production (e.g. port 6543)
DATABASE_URL="postgresql://four:four@localhost:5432/four"
# Prisma migrate CLI: direct URL when DATABASE_URL is pooled (optional locally)
# DIRECT_URL="postgresql://four:four@localhost:5432/four"

# Distributed rate limits (optional locally). When unset, limits are disabled.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# If the UI is hosted separately from the API, set the API origin (usually empty for Vercel same-origin)
# NEXT_PUBLIC_API_BASE=

# Anti-cheat: minimum accepted game duration for score submission (ms). Optional per-ply floor.
# SCORE_MIN_DURATION_MS=2500
# SCORE_MIN_MS_PER_PLY=350
# SCORE_MAX_DURATION_MS=129600000
