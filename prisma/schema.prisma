generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model LeaderboardEntry {
  id           String   @id @default(uuid())
  displayName  String   @map("display_name")
  difficulty   String
  basePoints   Int      @map("base_points")
  bonusPoints  Int      @map("bonus_points")
  totalScore   Int      @map("total_score")
  moveCount    Int      @map("move_count")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([totalScore(sort: Desc)])
  @@index([difficulty, totalScore(sort: Desc)])
  @@map("leaderboard_entries")
}

model DailyPuzzleEntry {
  id          String   @id @default(uuid())
  puzzleDate  DateTime @db.Date @map("puzzle_date")
  displayName String   @map("display_name")
  moveCount   Int      @map("move_count")
  durationMs  Int      @map("duration_ms")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([puzzleDate, displayName])
  @@index([puzzleDate, moveCount, durationMs])
  @@map("daily_puzzle_entries")
}
